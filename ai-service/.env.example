# Codesage AI Service environment variables (example)
# Copy this file to `.env` and fill secret values. Do NOT commit your `.env`.

# Codesage AI Service environment variables (example)
# Copy this file to `.env` and fill secret values. Do NOT commit your `.env`.

SERVICE_NAME=codesage-ai-service
ENVIRONMENT=development
SECRET_KEY=
API_KEY_HEADER=X-API-Key

REDIS_URL=redis://localhost:6379/0
REDIS_KEY_PREFIX=codesage
REDIS_CACHE_TTL_SECONDS=300
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
REPO_LOCK_TTL_SECONDS=1800
JOB_TTL_SECONDS=86400

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_PREFIX=codesage

EMBEDDING_MODEL=BAAI/bge-base-en-v1.5
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32

LLM_BACKEND=local
LLM_MODEL_PATH=./models/mistral-7b-instruct-v0.3.Q4_K_M.gguf
LLM_N_CTX=4096
LLM_N_GPU_LAYERS=0
LLM_N_THREADS=8
LLM_N_BATCH=512
LLM_TEMPERATURE=0.1
LLM_TOP_P=0.9
LLM_REPEAT_PENALTY=1.1
LLM_MAX_NEW_TOKENS=512

ALLOWED_ORIGINS=http://localhost:3000
SUPPORTED_EXTENSIONS=[".py", ".js", ".ts", ".go", ".java", ".md"]
MAX_REPO_SIZE_MB=100
CLONE_TIMEOUT_SEC=120

# Notes:
# - Provide SECRET_KEY before running the service.
# - Point LLM_MODEL_PATH at the GGUF file already mounted in ./models.
# - Keep secrets out of source control. Use a secrets manager in production.
